    <dependency>
      <groupId>com.qxotic</groupId>
      <artifactId>jam-native</artifactId>
      <!-- NativeJAM + the bundled libjam -->
    </dependency>
    <dependency>
      <groupId>com.qxotic</groupId>
      <artifactId>jam-vector</artifactId>
      <!-- VectorJAM + the relocated SIMD kernels -->
