    <dependency>
      <groupId>com.qxotic</groupId>
      <artifactId>graalvm-annotations</artifactId>
      <!-- @AlwaysInline: compile-only, not bundled; GraalVM supplies it at native-image build -->
      <scope>provided</scope>
