<?xml version="1.0" encoding="UTF-8"?>
<!--
  Maven build for lfm25.java. The source layout stays FLAT (jbang //SOURCES and the Makefile
  share it): main sources are the *.java files in the project root, tests live in tests/.
  buildtools/LFM25StaticGemmFeature.java is NOT built here - it needs GraalVM's unexported
  svm.jar internals and belongs to `make native-static-gemm`.

    mvn package                 fat jar -> target/lfm25.jar (run with the same flags as below)
    mvn -Pnative package        native image -> target/lfm25 (needs GraalVM >= 25.0.3, see
                                check-native-image in the Makefile; set JAVA_HOME accordingly)
    mvn spotless:check|apply    formatting hygiene (unused imports, whitespace)
    mvn exec:java -Dexec.mainClass=com.llama4j.KernelParityTest   kernel parity tests

  Run the fat jar:
    java -)-enable-preview -)-add-modules jdk.incubator.vector,jdk.httpserver \
         -)-enable-native-access=ALL-UNNAMED -Djdk.incubator.vector.VECTOR_ACCESS_OOB_CHECK=0 \
         -jar target/lfm25.jar -)-help        (replace "-)" with two dashes; XML comments
                                               cannot contain a double hyphen)
-->
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <groupId>com.llama4j</groupId>
    <artifactId>lfm25</artifactId>
    <version>0.1.0-SNAPSHOT</version>
    <packaging>jar</packaging>

    <name>lfm25.java</name>
    <description>LFM2.5 inference in pure Java (Vector API kernels, GGUF, OpenAI-compatible server)</description>

    <properties>
        <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
        <maven.compiler.release>25</maven.compiler.release>
        <!-- model baked into the image heap at build time; empty = none (see AOT.preLoadGGUF) -->
        <llama.PreloadGGUF></llama.PreloadGGUF>
    </properties>

    <dependencies>
        <dependency>
            <groupId>com.qxotic</groupId>
            <artifactId>gguf</artifactId>
            <version>0.1.0</version>
        </dependency>
        <dependency>
            <groupId>com.qxotic</groupId>
            <artifactId>toknroll-core</artifactId>
            <version>0.1.0</version>
        </dependency>
        <dependency>
            <groupId>com.qxotic</groupId>
            <artifactId>toknroll-gguf</artifactId>
            <version>0.1.0</version>
        </dependency>
        <!-- optional: thread pinning (-Dllama.Affinity=true); loaded reflectively, never
             required, and `provided` keeps it (and its JNA tree) OUT of the fat jar — put it
             on the classpath explicitly when pinning is wanted -->
        <dependency>
            <groupId>net.openhft</groupId>
            <artifactId>affinity</artifactId>
            <version>2026.2</version>
            <scope>provided</scope>
            <optional>true</optional>
        </dependency>
    </dependencies>

    <build>
        <!-- flat layout: root *.java are the main sources (non-recursive include below) -->
        <sourceDirectory>${project.basedir}</sourceDirectory>
        <testSourceDirectory>${project.basedir}/tests</testSourceDirectory>
        <finalName>lfm25</finalName>

        <plugins>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-compiler-plugin</artifactId>
                <version>3.14.0</version>
                <configuration>
                    <enablePreview>true</enablePreview>
                    <includes>
                        <include>*.java</include> <!-- root files only: not tests/, not buildtools/ -->
                    </includes>
                    <testIncludes>
                        <testInclude>*.java</testInclude>
                    </testIncludes>
                    <compilerArgs>
                        <arg>--add-modules</arg>
                        <arg>jdk.incubator.vector,jdk.httpserver</arg>
                    </compilerArgs>
                </configuration>
            </plugin>

            <!-- the parity/integration tests are plain main() programs, not JUnit: run them via
                 `make test` / `make test-server`, or mvn exec:java as shown in the header -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-surefire-plugin</artifactId>
                <version>3.5.2</version>
                <configuration>
                    <skipTests>true</skipTests>
                </configuration>
            </plugin>

            <!-- fat jar: target/lfm25.jar, self-contained except the model file -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-shade-plugin</artifactId>
                <version>3.6.0</version>
                <executions>
                    <execution>
                        <phase>package</phase>
                        <goals>
                            <goal>shade</goal>
                        </goals>
                        <configuration>
                            <createDependencyReducedPom>false</createDependencyReducedPom>
                            <transformers>
                                <transformer implementation="org.apache.maven.plugins.shade.resource.ManifestResourceTransformer">
                                    <mainClass>com.llama4j.LFM25</mainClass>
                                </transformer>
                            </transformers>
                            <filters>
                                <filter>
                                    <artifact>*:*</artifact>
                                    <excludes>
                                        <exclude>META-INF/*.SF</exclude>
                                        <exclude>META-INF/*.DSA</exclude>
                                        <exclude>META-INF/*.RSA</exclude>
                                    </excludes>
                                </filter>
                            </filters>
                        </configuration>
                    </execution>
                </executions>
            </plugin>

            <!-- formatting hygiene only (the very traps this codebase kept hitting: stale
                 imports, trailing whitespace). A full reformatter (palantirJavaFormat etc.)
                 would churn every file - enable deliberately if ever wanted. -->
            <plugin>
                <groupId>com.diffplug.spotless</groupId>
                <artifactId>spotless-maven-plugin</artifactId>
                <version>2.44.5</version>
                <configuration>
                    <java>
                        <includes>
                            <include>*.java</include>
                            <include>tests/*.java</include>
                            <include>buildtools/*.java</include>
                        </includes>
                        <removeUnusedImports/>
                        <trimTrailingWhitespace/>
                        <endWithNewline/>
                    </java>
                </configuration>
            </plugin>
        </plugins>
    </build>

    <profiles>
        <!-- mvn -Pnative package: native image with the same flags as `make native`.
             GraalVM >= 25.0.3 required (25.0.x earlier miscompiles the Vector API kernels);
             the statically-linked GEMM flavor stays in `make native-static-gemm` (unexported
             SVM internals). -->
        <profile>
            <id>native</id>
            <build>
                <plugins>
                    <plugin>
                        <groupId>org.graalvm.buildtools</groupId>
                        <artifactId>native-maven-plugin</artifactId>
                        <version>0.10.6</version>
                        <extensions>true</extensions>
                        <executions>
                            <execution>
                                <id>build-native</id>
                                <phase>package</phase>
                                <goals>
                                    <goal>compile-no-fork</goal>
                                </goals>
                            </execution>
                        </executions>
                        <configuration>
                            <imageName>lfm25</imageName>
                            <mainClass>com.llama4j.LFM25</mainClass>
                            <buildArgs>
                                <buildArg>-O3</buildArg>
                                <buildArg>-march=native</buildArg>
                                <buildArg>-H:+UnlockExperimentalVMOptions</buildArg>
                                <buildArg>-H:+VectorAPISupport</buildArg>
                                <buildArg>-H:+ForeignAPISupport</buildArg>
                                <buildArg>--enable-preview</buildArg>
                                <buildArg>--add-modules</buildArg>
                                <buildArg>jdk.incubator.vector,jdk.httpserver</buildArg>
                                <buildArg>--enable-native-access=ALL-UNNAMED</buildArg>
                                <buildArg>-J--enable-native-access=ALL-UNNAMED</buildArg>
                                <buildArg>--initialize-at-build-time=com.llama4j.AOT,com.llama4j.FloatTensor,com.llama4j.,com.qxotic.</buildArg>
                                <buildArg>--initialize-at-run-time=com.llama4j.RuntimeFlags,com.llama4j.ThreadAffinity</buildArg>
                                <buildArg>-Djdk.incubator.vector.VECTOR_ACCESS_OOB_CHECK=0</buildArg>
                                <buildArg>-Dllama.PreloadGGUF=${llama.PreloadGGUF}</buildArg>
                            </buildArgs>
                        </configuration>
                    </plugin>
                </plugins>
            </build>
        </profile>
    </profiles>
</project>
