<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
  <modelVersion>4.0.0</modelVersion>

  <parent>
    <groupId>com.qxotic</groupId>
    <artifactId>qxotic-parent</artifactId>
    <version>0.1.0</version>
  </parent>

  <artifactId>examples</artifactId>
  <name>Quixotic Examples</name>
  <description>Example applications demonstrating Quixotic AI usage</description>

  <properties>
    <!-- Examples require Java 25 for Jota integration -->
    <maven.compiler.source>25</maven.compiler.source>
    <maven.compiler.target>25</maven.compiler.target>
    <maven.compiler.release>25</maven.compiler.release>
    <maven.deploy.skip>true</maven.deploy.skip>
  </properties>

  <dependencies>
    <dependency>
      <groupId>com.qxotic</groupId>
      <artifactId>jota</artifactId>
    </dependency>
    <dependency>
      <groupId>com.qxotic</groupId>
      <artifactId>gguf</artifactId>
    </dependency>
    <dependency>
      <groupId>com.qxotic</groupId>
      <artifactId>tokenizers</artifactId>
    </dependency>

    <dependency>
      <groupId>com.qxotic</groupId>
      <artifactId>jota-backend-c</artifactId>
    </dependency>

    <dependency>
      <groupId>com.qxotic</groupId>
      <artifactId>jota-backend-hip</artifactId>
    </dependency>

    <dependency>
      <groupId>com.qxotic</groupId>
      <artifactId>jota-backend-metal</artifactId>
    </dependency>

    <dependency>
      <groupId>com.qxotic</groupId>
      <artifactId>jota-backend-cuda</artifactId>
    </dependency>

    <dependency>
      <groupId>com.qxotic</groupId>
      <artifactId>jota-backend-opencl</artifactId>
    </dependency>

    <dependency>
      <groupId>com.qxotic</groupId>
      <artifactId>jota-backend-mojo</artifactId>
    </dependency>

    <dependency>
      <groupId>com.qxotic</groupId>
      <artifactId>jota-graal</artifactId>
      <version>0.1.0</version>
    </dependency>

  </dependencies>

  <build>
    <plugins>
      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-compiler-plugin</artifactId>
        <configuration>
          <compilerArgs>
            <arg>--add-modules</arg>
            <arg>jdk.incubator.vector</arg>
          </compilerArgs>
        </configuration>
      </plugin>
      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-assembly-plugin</artifactId>
        <configuration>
          <descriptorRefs>
            <descriptorRef>jar-with-dependencies</descriptorRef>
          </descriptorRefs>
        </configuration>
      </plugin>
    </plugins>
  </build>

  <profiles>
    <profile>
      <id>jvm-panama</id>
      <activation>
        <activeByDefault>true</activeByDefault>
      </activation>
      <dependencies>
        <dependency>
          <groupId>com.qxotic</groupId>
          <artifactId>jota-backend-panama</artifactId>
        </dependency>
      </dependencies>
    </profile>

    <profile>
      <id>native-image</id>
    </profile>
  </profiles>
</project>
