<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <parent>
        <groupId>com.qxotic</groupId>
        <artifactId>qxotic-parent</artifactId>
        <version>0.1-SNAPSHOT</version>
        <relativePath>../pom.xml</relativePath>
    </parent>

    <artifactId>jota</artifactId>
    <name>Java Open Tensor Algebra</name>

    <properties>
        <maven.compiler.source>25</maven.compiler.source>
        <maven.compiler.target>25</maven.compiler.target>
        <native.c.dir>${project.basedir}/src/main/native</native.c.dir>
        <native.hip.dir>${project.basedir}/src/main/native/hip</native.hip.dir>
        <native.c.build.dir>${native.c.dir}/build</native.c.build.dir>
        <native.hip.build.dir>${native.hip.dir}/build</native.hip.build.dir>
        <rocm.path>${env.ROCM_PATH}</rocm.path>
    </properties>

    <dependencies>
        <dependency>
            <groupId>org.junit.jupiter</groupId>
            <artifactId>junit-jupiter</artifactId>
            <scope>test</scope>
        </dependency>
    </dependencies>

    <build>
        <plugins>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-surefire-plugin</artifactId>
                <configuration>
                    <!-- Exclude C and HIP backend tests from default run - use profiles to run them -->
                    <excludes>
                        <exclude>**/runtime/c/*Test.java</exclude>
                        <exclude>**/runtime/hip/*Test.java</exclude>
                    </excludes>
                    <systemPropertyVariables>
                        <jota.test.device>panama</jota.test.device>
                        <jota.test.backends>single</jota.test.backends>
                    </systemPropertyVariables>
                </configuration>
            </plugin>
        </plugins>
    </build>

    <profiles>
        <!-- C Runtime Profile: mvn compile -Pc or mvn test -Pc -->
        <profile>
            <id>c</id>
            <build>
                <plugins>
                    <plugin>
                        <groupId>org.codehaus.mojo</groupId>
                        <artifactId>exec-maven-plugin</artifactId>
                        <version>3.4.1</version>
                        <executions>
                            <execution>
                                <id>configure-native-c</id>
                                <phase>generate-sources</phase>
                                <goals>
                                    <goal>exec</goal>
                                </goals>
                                <configuration>
                                    <executable>cmake</executable>
                                    <arguments>
                                        <argument>-S</argument>
                                        <argument>${native.c.dir}</argument>
                                        <argument>-B</argument>
                                        <argument>${native.c.build.dir}</argument>
                                    </arguments>
                                </configuration>
                            </execution>
                            <execution>
                                <id>build-native-c</id>
                                <phase>compile</phase>
                                <goals>
                                    <goal>exec</goal>
                                </goals>
                                <configuration>
                                    <executable>cmake</executable>
                                    <arguments>
                                        <argument>--build</argument>
                                        <argument>${native.c.build.dir}</argument>
                                        <argument>--config</argument>
                                        <argument>Release</argument>
                                        <argument>--target</argument>
                                        <argument>jota_c</argument>
                                    </arguments>
                                </configuration>
                            </execution>
                        </executions>
                    </plugin>
                    <plugin>
                        <groupId>org.apache.maven.plugins</groupId>
                        <artifactId>maven-surefire-plugin</artifactId>
                        <configuration>
                            <!-- Override default excludes -->
                            <excludes combine.self="override"></excludes>
                            <includes>
                                <include>**/CBackendAvailabilityTest.java</include>
                                <include>**/CKernelSmokeTest.java</include>
                                <include>**/MandelbrotTest.java</include>
                                <include>**/TensorApiContractMatrixTest.java</include>
                                <include>**/TensorTypeContractMatrixTest.java</include>
                                <include>**/TensorScheduleIntegrationTest.java</include>
                                <include>**/KernelServiceTest.java</include>
                                <include>**/TIRTextRendererTest.java</include>
                                <include>**/ToOpTest.java</include>
                                <include>**/ConstantCreationAndArithmeticFoldingTest.java</include>
                                <include>**/ConstantFoldingCastTest.java</include>
                                <include>**/ConstantFoldingComparisonTest.java</include>
                                <include>**/ConstantFoldingBitwiseTest.java</include>
                                <include>**/AddTest.java</include>
                                <include>**/IotaOpTest.java</include>
                                <include>**/ApiExampleTest.java</include>
                                <include>**/BooleanTensorTest.java</include>
                                <include>**/RandomTensorTest.java</include>
                                <include>**/RandomTensorComprehensiveTest.java</include>
                                <include>**/RandomDistributionsTest.java</include>
                                <include>**/RandomGoldenVectorTest.java</include>
                                <include>**/GatherTraceLazyTest.java</include>
                                <include>**/WhereSemanticsContractTest.java</include>
                                <include>**/ReductionSemanticsContractTest.java</include>
                                <include>**/TypeRuleSemanticsContractTest.java</include>
                                <include>**/MaterializationSemanticsContractTest.java</include>
                                <include>**/SpiralGalaxyDemoTest.java</include>
                                <include>**/NBodySnapshotTest.java</include>
                                <include>**/TensorUsabilityExamplesTest.java</include>
                                <include>**/ComparisonOpTest.java</include>
                                <include>**/BitwiseOpTest.java</include>
                                <include>**/MaxReductionOpTest.java</include>
                                <include>**/MinReductionOpTest.java</include>
                                <include>**/ProductReductionOpTest.java</include>
                                <include>**/CastOpTest.java</include>
                                <include>**/ConcatOpTest.java</include>
                                <include>**/ContiguousOpTest.java</include>
                                <include>**/ReciprocalOpTest.java</include>
                                <include>**/GatherTest.java</include>
                                <include>**/ViewOpTest.java</include>
                                <include>**/ReshapeOpTest.java</include>
                                <include>**/SqueezeUnsqueezeOpTest.java</include>
                                <include>**/SumReductionOpTest.java</include>
                                <include>**/DotOpTest.java</include>
                                <include>**/ArgmaxOpTest.java</include>
                                <include>**/ArgminOpTest.java</include>
                                <include>**/StackOpTest.java</include>
                                <include>**/SplitOpTest.java</include>
                                <include>**/RepeatOpTest.java</include>
                                <include>**/RepeatInterleaveOpTest.java</include>
                                <include>**/WhereWithScalarBroadcastingTest.java</include>
                                <include>**/ShiftOpTest.java</include>
                                <include>**/MatmulOpTest.java</include>
                                <include>**/BooleanOpTest.java</include>
                            </includes>
                            <systemPropertyVariables>
                                <jota.test.device>c</jota.test.device>
                                <jota.test.backends>available</jota.test.backends>
                            </systemPropertyVariables>
                            <argLine>
                                -Djava.library.path=${native.c.build.dir}
                            </argLine>
                            <environmentVariables>
                                <LD_LIBRARY_PATH>${native.c.build.dir}:${env.LD_LIBRARY_PATH}</LD_LIBRARY_PATH>
                            </environmentVariables>
                        </configuration>
                    </plugin>
                </plugins>
            </build>
        </profile>

        <!-- HIP Runtime Profile: mvn compile -Phip or mvn test -Phip -->
        <profile>
            <id>hip</id>
            <build>
                <plugins>
                    <plugin>
                        <groupId>org.codehaus.mojo</groupId>
                        <artifactId>exec-maven-plugin</artifactId>
                        <version>3.4.1</version>
                        <executions>
                            <execution>
                                <id>check-hipcc</id>
                                <phase>validate</phase>
                                <goals>
                                    <goal>exec</goal>
                                </goals>
                                <configuration>
                                    <executable>hipcc</executable>
                                    <arguments>
                                        <argument>--version</argument>
                                    </arguments>
                                </configuration>
                            </execution>
                            <execution>
                                <id>configure-native-hip</id>
                                <phase>generate-sources</phase>
                                <goals>
                                    <goal>exec</goal>
                                </goals>
                                <configuration>
                                    <executable>cmake</executable>
                                    <arguments>
                                        <argument>-S</argument>
                                        <argument>${native.hip.dir}</argument>
                                        <argument>-B</argument>
                                        <argument>${native.hip.build.dir}</argument>
                                        <argument>-DROCM_PATH=${rocm.path}</argument>
                                    </arguments>
                                </configuration>
                            </execution>
                            <execution>
                                <id>build-native-hip</id>
                                <phase>compile</phase>
                                <goals>
                                    <goal>exec</goal>
                                </goals>
                                <configuration>
                                    <executable>cmake</executable>
                                    <arguments>
                                        <argument>--build</argument>
                                        <argument>${native.hip.build.dir}</argument>
                                        <argument>--config</argument>
                                        <argument>Release</argument>
                                        <argument>--target</argument>
                                        <argument>jota_hip</argument>
                                    </arguments>
                                </configuration>
                            </execution>
                        </executions>
                    </plugin>
                    <plugin>
                        <groupId>org.apache.maven.plugins</groupId>
                        <artifactId>maven-surefire-plugin</artifactId>
                        <configuration>
                            <!-- Override default excludes -->
                            <excludes combine.self="override"></excludes>
                            <includes>
                                <include>**/HipBackendAvailabilityTest.java</include>
                                <include>**/HipRuntimeDiagnosticsTest.java</include>
                                <include>**/HipKernelSmokeTest.java</include>
                                <include>**/MandelbrotTest.java</include>
                                <include>**/TensorApiContractMatrixTest.java</include>
                                <include>**/TensorTypeContractMatrixTest.java</include>
                                <include>**/TensorScheduleIntegrationTest.java</include>
                                <include>**/KernelServiceTest.java</include>
                                <include>**/TIRTextRendererTest.java</include>
                                <include>**/ToOpTest.java</include>
                                <include>**/ConstantCreationAndArithmeticFoldingTest.java</include>
                                <include>**/ConstantFoldingCastTest.java</include>
                                <include>**/ConstantFoldingComparisonTest.java</include>
                                <include>**/ConstantFoldingBitwiseTest.java</include>
                                <include>**/AddTest.java</include>
                                <include>**/IotaOpTest.java</include>
                                <include>**/ApiExampleTest.java</include>
                                <include>**/BooleanTensorTest.java</include>
                                <include>**/RandomTensorTest.java</include>
                                <include>**/RandomTensorComprehensiveTest.java</include>
                                <include>**/RandomDistributionsTest.java</include>
                                <include>**/RandomGoldenVectorTest.java</include>
                                <include>**/GatherTraceLazyTest.java</include>
                                <include>**/WhereSemanticsContractTest.java</include>
                                <include>**/ReductionSemanticsContractTest.java</include>
                                <include>**/TypeRuleSemanticsContractTest.java</include>
                                <include>**/MaterializationSemanticsContractTest.java</include>
                                <include>**/SpiralGalaxyDemoTest.java</include>
                                <include>**/NBodySnapshotTest.java</include>
                                <include>**/TensorUsabilityExamplesTest.java</include>
                                <include>**/ComparisonOpTest.java</include>
                                <include>**/BitwiseOpTest.java</include>
                                <include>**/MaxReductionOpTest.java</include>
                                <include>**/MinReductionOpTest.java</include>
                                <include>**/ProductReductionOpTest.java</include>
                                <include>**/CastOpTest.java</include>
                                <include>**/ConcatOpTest.java</include>
                                <include>**/ContiguousOpTest.java</include>
                                <include>**/ReciprocalOpTest.java</include>
                                <include>**/GatherTest.java</include>
                                <include>**/ViewOpTest.java</include>
                                <include>**/ReshapeOpTest.java</include>
                                <include>**/SqueezeUnsqueezeOpTest.java</include>
                                <include>**/SumReductionOpTest.java</include>
                                <include>**/DotOpTest.java</include>
                                <include>**/ArgmaxOpTest.java</include>
                                <include>**/ArgminOpTest.java</include>
                                <include>**/StackOpTest.java</include>
                                <include>**/SplitOpTest.java</include>
                                <include>**/RepeatOpTest.java</include>
                                <include>**/RepeatInterleaveOpTest.java</include>
                                <include>**/WhereWithScalarBroadcastingTest.java</include>
                                <include>**/ShiftOpTest.java</include>
                                <include>**/MatmulOpTest.java</include>
                                <include>**/BooleanOpTest.java</include>
                            </includes>
                            <systemPropertyVariables>
                                <jota.test.device>hip</jota.test.device>
                                <jota.test.backends>available</jota.test.backends>
                            </systemPropertyVariables>
                            <argLine>
                                -Djava.library.path=${native.hip.build.dir}
                            </argLine>
                            <environmentVariables>
                                <LD_LIBRARY_PATH>${native.hip.build.dir}:${rocm.path}/lib:/opt/rocm/lib:${env.LD_LIBRARY_PATH}</LD_LIBRARY_PATH>
                            </environmentVariables>
                        </configuration>
                    </plugin>
                </plugins>
            </build>
        </profile>

        <!-- Build both C and HIP: mvn compile -Pnative -->
        <profile>
            <id>native</id>
            <build>
                <plugins>
                    <plugin>
                        <groupId>org.codehaus.mojo</groupId>
                        <artifactId>exec-maven-plugin</artifactId>
                        <version>3.4.1</version>
                        <executions>
                            <!-- C Runtime -->
                            <execution>
                                <id>configure-native-c</id>
                                <phase>generate-sources</phase>
                                <goals>
                                    <goal>exec</goal>
                                </goals>
                                <configuration>
                                    <executable>cmake</executable>
                                    <arguments>
                                        <argument>-S</argument>
                                        <argument>${native.c.dir}</argument>
                                        <argument>-B</argument>
                                        <argument>${native.c.build.dir}</argument>
                                    </arguments>
                                </configuration>
                            </execution>
                            <execution>
                                <id>build-native-c</id>
                                <phase>compile</phase>
                                <goals>
                                    <goal>exec</goal>
                                </goals>
                                <configuration>
                                    <executable>cmake</executable>
                                    <arguments>
                                        <argument>--build</argument>
                                        <argument>${native.c.build.dir}</argument>
                                        <argument>--config</argument>
                                        <argument>Release</argument>
                                        <argument>--target</argument>
                                        <argument>jota_c</argument>
                                    </arguments>
                                </configuration>
                            </execution>
                            <!-- HIP Runtime -->
                            <execution>
                                <id>check-hipcc</id>
                                <phase>validate</phase>
                                <goals>
                                    <goal>exec</goal>
                                </goals>
                                <configuration>
                                    <executable>hipcc</executable>
                                    <arguments>
                                        <argument>--version</argument>
                                    </arguments>
                                </configuration>
                            </execution>
                            <execution>
                                <id>configure-native-hip</id>
                                <phase>generate-sources</phase>
                                <goals>
                                    <goal>exec</goal>
                                </goals>
                                <configuration>
                                    <executable>cmake</executable>
                                    <arguments>
                                        <argument>-S</argument>
                                        <argument>${native.hip.dir}</argument>
                                        <argument>-B</argument>
                                        <argument>${native.hip.build.dir}</argument>
                                        <argument>-DROCM_PATH=${rocm.path}</argument>
                                    </arguments>
                                </configuration>
                            </execution>
                            <execution>
                                <id>build-native-hip</id>
                                <phase>compile</phase>
                                <goals>
                                    <goal>exec</goal>
                                </goals>
                                <configuration>
                                    <executable>cmake</executable>
                                    <arguments>
                                        <argument>--build</argument>
                                        <argument>${native.hip.build.dir}</argument>
                                        <argument>--config</argument>
                                        <argument>Release</argument>
                                        <argument>--target</argument>
                                        <argument>jota_hip</argument>
                                    </arguments>
                                </configuration>
                            </execution>
                        </executions>
                    </plugin>
                </plugins>
            </build>
        </profile>
    </profiles>
</project>
