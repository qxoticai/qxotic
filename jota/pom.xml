<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
  <modelVersion>4.0.0</modelVersion>

  <parent>
    <groupId>com.qxotic</groupId>
    <artifactId>qxotic-parent</artifactId>
    <version>0.1.0</version>
    <relativePath>../pom.xml</relativePath>
  </parent>

  <artifactId>jota-aggregator</artifactId>
  <packaging>pom</packaging>
  <name>Jota Aggregator</name>
  <description>JVM Open Tensor Algebra - Multi-backend tensor computation library</description>

  <modules>
    <module>jota-core</module>
    <module>jota-backend-panama</module>
    <module>jota-backend-c</module>
    <module>jota-graal</module>
    <module>jota-backend-hip</module>
    <module>jota-backend-metal</module>
    <module>jota-backend-opencl</module>
  </modules>

  <properties>
    <!-- Java 25 required for Jota (FFM API, Vector API) -->
    <maven.compiler.source>25</maven.compiler.source>
    <maven.compiler.target>25</maven.compiler.target>
    <maven.compiler.release>25</maven.compiler.release>

    <!-- Test configuration -->
    <jota.test.device>panama</jota.test.device>
    <jota.test.backends>single</jota.test.backends>
    <jota.native.backend>native</jota.native.backend>

    <!-- Backend test skipping (all disabled by default) -->
    <skipTests.backend.c>true</skipTests.backend.c>
    <skipTests.backend.panama>true</skipTests.backend.panama>
    <skipTests.backend.hip>true</skipTests.backend.hip>
    <skipTests.backend.metal>true</skipTests.backend.metal>
    <skipTests.backend.opencl>true</skipTests.backend.opencl>

    <!-- Native build skipping (all disabled by default) -->
    <skipNative.backend.c>true</skipNative.backend.c>
    <skipNative.backend.hip>true</skipNative.backend.hip>
    <skipNative.backend.metal>true</skipNative.backend.metal>
    <skipNative.backend.opencl>true</skipNative.backend.opencl>

    <!-- Core tests run by default -->
    <skipTests.backend.core>false</skipTests.backend.core>

    <!-- Shared native backend build properties (overridden per backend module) -->
    <native.dir>${project.basedir}/src/main/native</native.dir>
    <native.build.dir>${native.dir}/build</native.build.dir>
    <native.resource.dir>${project.build.outputDirectory}/META-INF/native/${os.name}/${os.arch}</native.resource.dir>
    <os.name>linux</os.name>
    <os.arch>x86_64</os.arch>
    <native.cmake.executable>cmake</native.cmake.executable>
    <native.build.type>Release</native.build.type>
    <native.configure.extraArgs />
    <native.build.extraArgs />
    <native.configure.commandline>-S ${native.dir} -B ${native.build.dir} ${native.configure.extraArgs}</native.configure.commandline>
    <native.build.commandline>--build ${native.build.dir} --config ${native.build.type} --target ${native.library.basename} ${native.build.extraArgs}</native.build.commandline>
    <native.library.basename>unset</native.library.basename>
    <native.copy.skip>true</native.copy.skip>
    <native.skip.tests>true</native.skip.tests>
    <native.skip.build>true</native.skip.build>
  </properties>

  <build>
    <pluginManagement>
      <plugins>

        <plugin>
          <groupId>org.apache.maven.plugins</groupId>
          <artifactId>maven-surefire-plugin</artifactId>
          <configuration>
            <systemPropertyVariables>
              <jota.test.device>${jota.test.device}</jota.test.device>
              <jota.test.backends>${jota.test.backends}</jota.test.backends>
              <jota.native.backend>${jota.native.backend}</jota.native.backend>
            </systemPropertyVariables>
          </configuration>
        </plugin>
        <plugin>
          <groupId>org.apache.maven.plugins</groupId>
          <artifactId>maven-resources-plugin</artifactId>
          <executions>
            <execution>
              <id>copy-native-backend</id>
              <goals>
                <goal>copy-resources</goal>
              </goals>
              <phase>process-resources</phase>
              <configuration>
                <skip>${native.copy.skip}</skip>
                <outputDirectory>${native.resource.dir}</outputDirectory>
                <resources>
                  <resource>
                    <directory>${native.build.dir}</directory>
                    <includes>
                      <include>lib${native.library.basename}.so</include>
                      <include>lib${native.library.basename}.dylib</include>
                      <include>${native.library.basename}.dll</include>
                    </includes>
                  </resource>
                </resources>
              </configuration>
            </execution>
          </executions>
        </plugin>
        <plugin>
          <groupId>org.codehaus.mojo</groupId>
          <artifactId>exec-maven-plugin</artifactId>
          <executions>
            <execution>
              <id>configure-native</id>
              <goals>
                <goal>exec</goal>
              </goals>
              <phase>generate-sources</phase>
              <configuration>
                <skip>${native.skip.build}</skip>
                <executable>${native.cmake.executable}</executable>
                <commandlineArgs>${native.configure.commandline}</commandlineArgs>
              </configuration>
            </execution>
            <execution>
              <id>build-native</id>
              <goals>
                <goal>exec</goal>
              </goals>
              <phase>compile</phase>
              <configuration>
                <skip>${native.skip.build}</skip>
                <executable>${native.cmake.executable}</executable>
                <commandlineArgs>${native.build.commandline}</commandlineArgs>
              </configuration>
            </execution>
          </executions>
        </plugin>
      </plugins>
    </pluginManagement>
  </build>

  <profiles>
    <!-- Panama Backend Profile -->
    <profile>
      <id>panama</id>
      <properties>
        <jota.test.device>panama</jota.test.device>
        <jota.test.backends>single</jota.test.backends>
        <jota.native.backend>panama</jota.native.backend>
        <skipTests.backend.core>true</skipTests.backend.core>
        <skipTests.backend.panama>false</skipTests.backend.panama>
      </properties>
    </profile>

    <!-- C Backend Profile -->
    <profile>
      <id>c</id>
      <properties>
        <jota.test.device>c</jota.test.device>
        <jota.test.backends>single</jota.test.backends>
        <jota.native.backend>c</jota.native.backend>
        <skipTests.backend.core>true</skipTests.backend.core>
        <skipTests.backend.c>false</skipTests.backend.c>
        <skipNative.backend.c>false</skipNative.backend.c>
      </properties>
      <build>
        <plugins>
          <plugin>
            <groupId>org.codehaus.mojo</groupId>
            <artifactId>exec-maven-plugin</artifactId>
            <executions>
              <execution>
                <id>check-toolchain-cmake</id>
                <goals>
                  <goal>exec</goal>
                </goals>
                <phase>validate</phase>
                <configuration>
                  <skip>${skipNative.backend.c}</skip>
                  <executable>/bin/sh</executable>
                  <arguments>
                    <argument>-c</argument>
                    <argument>command -v "${native.cmake.executable}" &gt;/dev/null 2&gt;&amp;1 || [ -x "${native.cmake.executable}" ] ||
                                            (echo "[ERROR] CMake executable not found: ${native.cmake.executable}" &amp;&amp;
echo "[ERROR] Required for -Pc profile (C backend native builds)" &amp;&amp;
echo "[ERROR] Install CMake:" &amp;&amp;
echo "[ERROR]   Ubuntu/Debian: sudo apt install cmake" &amp;&amp;
echo "[ERROR]   RHEL/CentOS: sudo dnf install cmake" &amp;&amp;
echo "[ERROR]   macOS: brew install cmake" &amp;&amp;
echo "[ERROR]   See: https://cmake.org/download/" &amp;&amp;
exit 1)</argument>
                  </arguments>
                </configuration>
              </execution>
            </executions>
          </plugin>
        </plugins>
      </build>
    </profile>

    <!-- HIP Backend Profile -->
    <profile>
      <id>hip</id>
      <properties>
        <jota.test.device>hip</jota.test.device>
        <jota.test.backends>single</jota.test.backends>
        <jota.native.backend>panama</jota.native.backend>
        <skipTests.backend.core>true</skipTests.backend.core>
        <skipTests.backend.hip>false</skipTests.backend.hip>
        <skipNative.backend.hip>false</skipNative.backend.hip>
      </properties>
      <build>
        <plugins>
          <plugin>
            <groupId>org.codehaus.mojo</groupId>
            <artifactId>exec-maven-plugin</artifactId>
            <executions>
              <execution>
                <id>check-toolchain-hip</id>
                <goals>
                  <goal>exec</goal>
                </goals>
                <phase>validate</phase>
                <configuration>
                  <skip>${skipNative.backend.hip}</skip>
                  <executable>/bin/sh</executable>
                  <arguments>
                    <argument>-c</argument>
                    <argument>command -v hipcc &amp;&amp; exit 0 ||
                                            (echo "[ERROR] HIP compiler (hipcc) not found in PATH" &amp;&amp;
echo "[ERROR] Required for -Phip profile (AMD GPU backend)" &amp;&amp;
echo "[ERROR] Install ROCm:" &amp;&amp;
echo "[ERROR]   Ubuntu 22.04: https://rocm.docs.amd.com/projects/install-on-linux/en/latest/tutorial/quick-start.html#ubuntu" &amp;&amp;
echo "[ERROR]   RHEL/Rocky: https://rocm.docs.amd.com/projects/install-on-linux/en/latest/tutorial/quick-start.html#rhel" &amp;&amp;
echo "[ERROR]   Ensure ROCM_PATH is set (e.g., /opt/rocm)" &amp;&amp;
echo "[ERROR]   Add to PATH: export PATH=\$ROCM_PATH/bin:\$PATH" &amp;&amp;
exit 1)</argument>
                  </arguments>
                </configuration>
              </execution>
            </executions>
          </plugin>
        </plugins>
      </build>
    </profile>

    <!-- Metal Backend Profile -->
    <profile>
      <id>metal</id>
      <properties>
        <jota.test.device>metal</jota.test.device>
        <jota.test.backends>single</jota.test.backends>
        <jota.native.backend>panama</jota.native.backend>
        <skipTests.backend.core>true</skipTests.backend.core>
        <skipTests.backend.metal>false</skipTests.backend.metal>
        <skipNative.backend.metal>false</skipNative.backend.metal>
      </properties>
      <build>
        <plugins>
          <plugin>
            <groupId>org.codehaus.mojo</groupId>
            <artifactId>exec-maven-plugin</artifactId>
            <executions>
              <execution>
                <id>check-toolchain-metal</id>
                <goals>
                  <goal>exec</goal>
                </goals>
                <phase>validate</phase>
                <configuration>
                  <skip>${skipNative.backend.metal}</skip>
                  <executable>/bin/sh</executable>
                  <arguments>
                    <argument>-c</argument>
                    <argument>if [ "$(uname)" != "Darwin" ]; then
                                                echo "[ERROR] Metal backend is only supported on macOS"
                                                echo "[ERROR] Current OS: $(uname)"
                                                exit 1
                                            fi
                                            command -v xcrun &amp;&amp; exit 0 ||
                                            (echo "[ERROR] Xcode command line tools (xcrun) not found" &amp;&amp;
echo "[ERROR] Required for -Pmetal profile (Apple Metal backend)" &amp;&amp;
echo "[ERROR] Install: xcode-select --install" &amp;&amp;
exit 1)</argument>
                  </arguments>
                </configuration>
              </execution>
            </executions>
          </plugin>
        </plugins>
      </build>
    </profile>

    <!-- OpenCL Backend Profile -->
    <profile>
      <id>opencl</id>
      <properties>
        <jota.test.device>opencl</jota.test.device>
        <jota.test.backends>single</jota.test.backends>
        <jota.native.backend>panama</jota.native.backend>
        <skipTests.backend.core>true</skipTests.backend.core>
        <skipTests.backend.opencl>false</skipTests.backend.opencl>
        <skipNative.backend.opencl>false</skipNative.backend.opencl>
      </properties>
      <build>
        <plugins>
          <plugin>
            <groupId>org.codehaus.mojo</groupId>
            <artifactId>exec-maven-plugin</artifactId>
            <executions>
              <execution>
                <id>check-toolchain-opencl</id>
                <goals>
                  <goal>exec</goal>
                </goals>
                <phase>validate</phase>
                <configuration>
                  <skip>${skipNative.backend.opencl}</skip>
                  <executable>/bin/sh</executable>
                  <arguments>
                    <argument>-c</argument>
                    <argument>command -v "${native.cmake.executable}" &gt;/dev/null 2&gt;&amp;1 || [ -x "${native.cmake.executable}" ] ||
                                            (echo "[ERROR] CMake executable not found: ${native.cmake.executable}" &amp;&amp;
echo "[ERROR] Required for -Popencl profile (OpenCL backend native builds)" &amp;&amp;
echo "[ERROR] Install CMake:" &amp;&amp;
echo "[ERROR]   Ubuntu/Debian: sudo apt install cmake" &amp;&amp;
echo "[ERROR]   RHEL/CentOS: sudo dnf install cmake" &amp;&amp;
echo "[ERROR]   macOS: brew install cmake" &amp;&amp;
echo "[ERROR]   Also install OpenCL headers and runtime for your platform" &amp;&amp;
exit 1)</argument>
                  </arguments>
                </configuration>
              </execution>
            </executions>
          </plugin>
        </plugins>
      </build>
    </profile>

    <!-- All Backends Profile: test all available backends -->
    <profile>
      <id>all</id>
      <properties>
        <jota.test.backends>available</jota.test.backends>
        <!-- Enable all backends for testing -->
        <skipTests.backend.panama>false</skipTests.backend.panama>
        <skipTests.backend.c>false</skipTests.backend.c>
        <skipTests.backend.opencl>false</skipTests.backend.opencl>
        <!-- HIP and Metal are platform-specific, handled by other profiles -->
      </properties>
    </profile>

    <!-- Shared platform detection for backend native packaging -->
    <profile>
      <id>native-windows</id>
      <activation>
        <os>
          <family>windows</family>
        </os>
      </activation>
      <properties>
        <os.name>windows</os.name>
        <os.arch>x86_64</os.arch>
      </properties>
    </profile>
    <profile>
      <id>native-linux</id>
      <activation>
        <os>
          <name>Linux</name>
        </os>
      </activation>
      <properties>
        <os.name>linux</os.name>
      </properties>
    </profile>
    <profile>
      <id>native-macos</id>
      <activation>
        <os>
          <family>mac</family>
        </os>
      </activation>
      <properties>
        <os.name>macos</os.name>
      </properties>
    </profile>

    <!-- CI profile: native builds expected from matrix artifacts -->
    <profile>
      <id>ci-natives</id>
      <activation>
        <property>
          <name>env.CI</name>
        </property>
      </activation>
      <properties>
        <skipNative.backend.c>true</skipNative.backend.c>
        <skipNative.backend.hip>true</skipNative.backend.hip>
        <skipNative.backend.metal>true</skipNative.backend.metal>
        <skipNative.backend.opencl>true</skipNative.backend.opencl>
      </properties>
    </profile>

    <!-- HIP is unsupported on macOS -->
    <profile>
      <id>hip-macos-skip</id>
      <activation>
        <os>
          <family>mac</family>
        </os>
      </activation>
      <properties>
        <skipNative.backend.hip>true</skipNative.backend.hip>
      </properties>
    </profile>

    <!-- Auto-activation: Metal on macOS -->
    <profile>
      <id>metal-macos</id>
      <activation>
        <os>
          <family>mac</family>
        </os>
      </activation>
      <properties>
        <skipNative.backend.metal>false</skipNative.backend.metal>
        <skipTests.backend.metal>false</skipTests.backend.metal>
      </properties>
    </profile>
  </profiles>
</project>
