<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <parent>
        <groupId>ai.qxotic</groupId>
        <artifactId>jota-modules</artifactId>
        <version>0.1-SNAPSHOT</version>
        <relativePath>../pom.xml</relativePath>
    </parent>

    <artifactId>jota-runtime-c</artifactId>
    <name>Jota C Runtime</name>

    <properties>
        <maven.compiler.source>25</maven.compiler.source>
        <maven.compiler.target>25</maven.compiler.target>
        <maven.test.skip>true</maven.test.skip>
        <jota.native.build.dir>${project.basedir}/native/build</jota.native.build.dir>
    </properties>

    <dependencies>
        <dependency>
            <groupId>ai.qxotic</groupId>
            <artifactId>jota-core</artifactId>
            <version>${project.version}</version>
        </dependency>
        <dependency>
            <groupId>org.junit.jupiter</groupId>
            <artifactId>junit-jupiter</artifactId>
            <scope>test</scope>
        </dependency>
    </dependencies>

    <build/>

    <profiles>
        <profile>
            <id>c</id>
            <properties>
                <maven.test.skip>false</maven.test.skip>
            </properties>
            <build>
                <plugins>
                    <plugin>
                        <groupId>org.codehaus.mojo</groupId>
                        <artifactId>exec-maven-plugin</artifactId>
                        <version>3.4.1</version>
                        <executions>
                            <execution>
                                <id>configure-native-c</id>
                                <phase>generate-sources</phase>
                                <goals>
                                    <goal>exec</goal>
                                </goals>
                                <configuration>
                                    <executable>cmake</executable>
                                    <arguments>
                                        <argument>-S</argument>
                                        <argument>${project.basedir}/native</argument>
                                        <argument>-B</argument>
                                        <argument>${jota.native.build.dir}</argument>
                                    </arguments>
                                </configuration>
                            </execution>
                            <execution>
                                <id>build-native-c</id>
                                <phase>compile</phase>
                                <goals>
                                    <goal>exec</goal>
                                </goals>
                                <configuration>
                                    <executable>cmake</executable>
                                    <arguments>
                                        <argument>--build</argument>
                                        <argument>${jota.native.build.dir}</argument>
                                        <argument>--config</argument>
                                        <argument>Release</argument>
                                        <argument>--target</argument>
                                        <argument>jota_c</argument>
                                    </arguments>
                                </configuration>
                            </execution>
                        </executions>
                    </plugin>
                    <plugin>
                        <artifactId>maven-surefire-plugin</artifactId>
                        <configuration>
                            <includes>
                                <include>**/CKernelSmokeTest.java</include>
                                <include>**/CMatmulKernelSmokeTest.java</include>
                            </includes>
                            <argLine>
                                -Djava.library.path=${jota.native.build.dir}
                            </argLine>
                            <environmentVariables>
                                <LD_LIBRARY_PATH>${jota.native.build.dir}:${env.LD_LIBRARY_PATH}</LD_LIBRARY_PATH>
                            </environmentVariables>
                        </configuration>
                    </plugin>
                </plugins>
            </build>
        </profile>
    </profiles>
</project>
