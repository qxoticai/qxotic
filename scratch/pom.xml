<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <parent>
        <groupId>com.llm4j</groupId>
        <artifactId>llm4j-parent</artifactId>
        <version>${llm4j.version}</version>
    </parent>

    <artifactId>scratch</artifactId>
    <name>llm4j Models + CLI</name>

    <properties>
        <auto-service.version>1.1.0</auto-service.version>
        <native-maven-plugin.version>0.11.0</native-maven-plugin.version>

        <maven.compiler.source>25</maven.compiler.source>
        <maven.compiler.target>25</maven.compiler.target>
    </properties>

    <dependencies>

        <dependency>
            <groupId>com.google.auto.service</groupId>
            <artifactId>auto-service-annotations</artifactId>
            <version>${auto-service.version}</version>
        </dependency>

        <dependency>
            <groupId>net.sourceforge.f2j</groupId>
            <artifactId>arpack_combined_all</artifactId>
            <version>0.1</version>
        </dependency>

        <dependency>
            <groupId>net.sourceforge.streamsupport</groupId>
            <artifactId>dedekind-mkl</artifactId>
            <version>1.1.0</version>
        </dependency>

        <dependency>
            <groupId>com.llm4j</groupId>
            <artifactId>api</artifactId>
        </dependency>

        <dependency>
            <groupId>com.llm4j</groupId>
            <artifactId>gguf</artifactId>
        </dependency>

        <dependency>
            <groupId>com.llm4j</groupId>
            <artifactId>huggingface</artifactId>
        </dependency>

        <dependency>
            <groupId>com.llm4j</groupId>
            <artifactId>tokenizers</artifactId>
        </dependency>

        <dependency>
            <groupId>com.llm4j</groupId>
            <artifactId>span</artifactId>
        </dependency>

        <dependency>
            <groupId>org.junit.jupiter</groupId>
            <artifactId>junit-jupiter</artifactId>
            <scope>test</scope>
        </dependency>
    </dependencies>

    <build>
        <plugins>
            <!-- Activate compiler plugin only for this module and add incubator module -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-compiler-plugin</artifactId>
                <configuration>
                    <release>24</release>
                    <compilerArgs>
                        <arg>--add-modules</arg>
                        <arg>jdk.incubator.vector</arg>
                    </compilerArgs>
                    <annotationProcessorPaths>
                        <path>
                            <groupId>com.google.auto.service</groupId>
                            <artifactId>auto-service</artifactId>
                            <version>${auto-service.version}</version>
                        </path>
                    </annotationProcessorPaths>
                </configuration>
            </plugin>

            <!-- Ensure tests also see the incubator module -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-surefire-plugin</artifactId>
                <configuration>
                    <argLine>--add-modules jdk.incubator.vector</argLine>
                </configuration>
            </plugin>

            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-assembly-plugin</artifactId>

                <configuration>
                    <descriptorRefs>
                        <descriptorRef>jar-with-dependencies</descriptorRef>
                    </descriptorRefs>
                    <archive>
                        <manifest>
                            <mainClass>com.llm4j.model.generic.Main</mainClass>
                        </manifest>
                    </archive>
                </configuration>
            </plugin>

        </plugins>
    </build>

    <profiles>
        <profile>
            <id>native</id>
            <build>
                <plugins>

                    <plugin>
                        <groupId>org.graalvm.buildtools</groupId>
                        <artifactId>native-maven-plugin</artifactId>
                        <version>${native-maven-plugin.version}</version>
                        <extensions>true</extensions>
                        <executions>
                            <execution>
                                <id>build-native</id>
                                <goals>
                                    <goal>compile-no-fork</goal>
                                </goals>
                                <phase>package</phase>
                            </execution>
                        </executions>
                        <configuration>
                            <mainClass>com.llm4j.model.generic.Main</mainClass>
                            <imageName>llm4j-cli</imageName>
                            <buildArgs>
                                <!-- enables additional compiler optimizations -->
                                <buildArg>-O3</buildArg>
                                <!--<buildArg>-march=native</buildArg>-->
                                <buildArg>--no-fallback</buildArg>
                                <buildArg>-H:+UnlockExperimentalVMOptions</buildArg>
                                <buildArg>-H:+VectorAPISupport</buildArg>
                                <buildArg>-H:+ForeignAPISupport</buildArg>
                                <buildArg>--initialize-at-build-time=com.llm4j.model.llama.PanamaKernelOps</buildArg>
                            </buildArgs>
                            <environment>
                                <!--<variable1>value1</variable1>-->
                                <!--<variable2>value2</variable2>-->
                            </environment>
                            <jvmArgs>
                                <arg>--enable-preview</arg>
                                <arg>--add-modules</arg>
                                <arg>jdk.incubator.vector</arg>
                                <arg>-Djdk.incubator.vector.VECTOR_ACCESS_OOB_CHECK=0</arg>
                            </jvmArgs>
                        </configuration>
                    </plugin>

                </plugins>
            </build>
        </profile>
    </profiles>

</project>
