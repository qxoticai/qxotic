package com.qxotic.toknroll.impl;

import com.qxotic.toknroll.IntSequence;
import com.qxotic.toknroll.TokenizationModel;
import com.qxotic.toknroll.Vocabulary;
import java.nio.ByteBuffer;
import java.nio.charset.StandardCharsets;
import java.util.Arrays;
import java.util.Map;
import java.util.Objects;

final class SentencePieceBpeModel extends AbstractTokenizationModel {

    private static final int NO_INDEX = -1;

    private final LongLongMap packedMerges;

    private SentencePieceBpeModel(Vocabulary vocabulary, LongLongMap packedMerges) {
        super(vocabulary);
        this.packedMerges = Objects.requireNonNull(packedMerges, "packedMerges");
    }

    static long packMerge(int rank, int mergedId) {
        return IntPair.of(mergedId, rank);
    }

    static SentencePieceBpeModel fromVocabularyAndMerges(
            Vocabulary vocabulary, LongLongMap directMerges) {
        Objects.requireNonNull(vocabulary, "vocabulary");
        return new SentencePieceBpeModel(vocabulary, directMerges);
    }

    @Override
    public float expectedTokensPerChar() {
        return 0.5f;
    }

    @Override
    protected IntSequence encodeImpl(CharSequence text) {
        IntSequence.Builder out = IntSequence.newBuilder(Math.max(8, text.length()));
        encodeImplInto(text, out);
        return out.build();
    }

    @Override
    protected void encodeImplInto(CharSequence text, IntSequence.Builder out) {
        if (text.length() == 0) {
            return;
        }

        int[] tokens = new int[text.length()];
        int size = 0;
        for (int i = 0; i < text.length(); i++) {
            char c = text.charAt(i);
            if (Character.isHighSurrogate(c) && i + 1 < text.length()
                    && Character.isLowSurrogate(text.charAt(i + 1))) {
                int cp = Character.toCodePoint(c, text.charAt(i + 1));
                tokens[size++] = cpToTokenId(cp);
                i++;
            } else {
                tokens[size++] = cpToTokenId(c);
            }
        }

        int[] pairRanks = new int[Math.max(0, size - 1)];
        Arrays.fill(pairRanks, Integer.MAX_VALUE);
        for (int i = 0; i + 1 < size; i++) {
            long packed = packedMerges.getPair(tokens[i], tokens[i + 1]);
            if (packed != IntPair.NONE) {
                pairRanks[i] = IntPair.right(packed);
            }
        }

        while (size >= 2) {
            int bestRank = Integer.MAX_VALUE;
            int bestPos = NO_INDEX;
            for (int i = 0; i + 1 < size; i++) {
                if (pairRanks[i] < bestRank) {
                    bestRank = pairRanks[i];
                    bestPos = i;
                }
            }
            if (bestPos == NO_INDEX) {
                break;
            }

            long packed = packedMerges.getPair(tokens[bestPos], tokens[bestPos + 1]);
            int mergedId = IntPair.left(packed);

            tokens[bestPos] = mergedId;
            int tail = size - bestPos - 2;
            if (tail > 0) {
                System.arraycopy(tokens, bestPos + 2, tokens, bestPos + 1, tail);
                System.arraycopy(pairRanks, bestPos + 1, pairRanks, bestPos, tail);
            }
            size--;

            int newPairCount = size - 1;
            if (bestPos > 0) {
                long p = packedMerges.getPair(tokens[bestPos - 1], tokens[bestPos]);
                pairRanks[bestPos - 1] = (p != IntPair.NONE) ? IntPair.right(p) : Integer.MAX_VALUE;
            }
            if (bestPos < newPairCount) {
                long p = packedMerges.getPair(tokens[bestPos], tokens[bestPos + 1]);
                pairRanks[bestPos] = (p != IntPair.NONE) ? IntPair.right(p) : Integer.MAX_VALUE;
            }
        }

        out.ensureCapacity(out.size() + size);
        for (int i = 0; i < size; i++) {
            out.add(tokens[i]);
        }
    }

    @Override
    public void encodeInto(
            CharSequence text, int startInclusive, int endExclusive, IntSequence.Builder out) {
        Objects.requireNonNull(text, "text");
        Objects.requireNonNull(out, "out");
        if (startInclusive < 0 || endExclusive < startInclusive || endExclusive > text.length()) {
            throw new IndexOutOfBoundsException(
                    "Invalid range [" + startInclusive + ", " + endExclusive
                            + ") for text length " + text.length());
        }
        encodeImplInto(text.subSequence(startInclusive, endExclusive), out);
    }

    @Override
    public int countTokens(CharSequence text, int startInclusive, int endExclusive) {
        Objects.requireNonNull(text, "text");
        IntSequence.Builder out = IntSequence.newBuilder(Math.max(8, endExclusive - startInclusive));
        encodeInto(text, startInclusive, endExclusive, out);
        return out.size();
    }

    @Override
    public byte[] decodeBytes(IntSequence tokens) {
        Objects.requireNonNull(tokens, "tokens");
        StringBuilder sb = new StringBuilder(tokens.length());
        for (int i = 0; i < tokens.length(); i++) {
            int tokenId = tokens.intAt(i);
            sb.append(vocabulary.token(tokenId));
        }
        return sb.toString().getBytes(StandardCharsets.UTF_8);
    }

    @Override
    public int countBytes(IntSequence tokens) {
        return decodeBytes(tokens).length;
    }

    @Override
    public int decodeBytesInto(IntSequence tokens, int tokenStartIndex, ByteBuffer out) {
        Objects.requireNonNull(tokens, "tokens");
        Objects.requireNonNull(out, "out");
        int length = tokens.length();
        if (tokenStartIndex < 0 || tokenStartIndex > length) {
            throw new IndexOutOfBoundsException("tokenStartIndex: " + tokenStartIndex);
        }
        int consumed = 0;
        for (int i = tokenStartIndex; i < length; i++) {
            int tokenId = tokens.intAt(i);
            String tokenStr = vocabulary.token(tokenId);
            byte[] bytes = tokenStr.getBytes(StandardCharsets.UTF_8);
            if (bytes.length > out.remaining()) {
                break;
            }
            out.put(bytes);
            consumed++;
        }
        return consumed;
    }

    private int cpToTokenId(int codePoint) {
        String token = vocabulary.contains(codePoint) ? String.valueOf((char) codePoint) : null;
        // Try code point as string
        try {
            return vocabulary.id(String.valueOf(Character.toChars(codePoint)));
        } catch (Exception e) {
            throw new IllegalArgumentException(
                    "No token for code point: " + codePoint + " (U+" + Integer.toHexString(codePoint) + ")");
        }
    }
}
